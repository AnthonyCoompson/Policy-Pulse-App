# PolicyPulse Backend — Environment Variables
# Copy these to Railway: Settings → Variables

# ── Required ──────────────────────────────────────────────
# Google Gemini API key (free at aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Security (strongly recommended) ──────────────────────
# API key that protects all write endpoints on the backend.
# Generate one with:  openssl rand -hex 32
# Then paste the same value into Railway AND into your app's
# localStorage key pp_api_key (the app reads it on boot).
PP_API_KEY=your_random_secret_key_here

# Comma-separated list of allowed frontend origins (no trailing slash).
# Example:  https://policypulse.netlify.app,https://policypulse.ca
# Leave blank to allow all origins (NOT recommended in production).
ALLOWED_ORIGINS=https://your-site.netlify.app

# ── Optional ──────────────────────────────────────────────
# SQLite database path (Railway persists this automatically)
DB_PATH=policypulse.db

# Port (Railway sets this automatically — leave as-is)
PORT=8000

# ── Email (needed for real digest sending) ────────────────
# Gmail: use an App Password (Google Account → Security → App passwords)
# Outlook/Office 365: use smtp.office365.com, port 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=PolicyPulse <your.email@gmail.com>
